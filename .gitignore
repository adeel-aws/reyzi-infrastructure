# =============================================================
#  Terraform — State & Lock Files
# =============================================================
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl

# =============================================================
#  Terraform — Working Directory
# =============================================================
.terraform/
.terraform.tfstate.lock.info

# =============================================================
#  Sensitive Variable Files
#  tfvars.example is committed — actual tfvars are NOT
# =============================================================

!*.tfvars.example

# =============================================================
#  Crash & Override Files
# =============================================================
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================
#  Plan Files (may contain sensitive data)
# =============================================================
*.tfplan
*.plan

# =============================================================
#  CLI Config
# =============================================================
.terraformrc
terraform.rc

# =============================================================
#  OS & Editor
# =============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================
#  Environment Files
# =============================================================
.env
.env.*
!.env.example
.git